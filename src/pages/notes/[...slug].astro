---
import { type CollectionEntry, render } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';
import Accordion from '../../components/Accordion.astro';
import Definition from '../../components/Definition.astro';
import CodeFilename from '../../components/CodeFilename.astro';
import Playground from '../../components/Playground.astro';
import { getPublishedNotes } from '../../lib/notes';

export async function getStaticPaths() {
  const posts = await getPublishedNotes();
  return posts.map((post) => ({
    params: { slug: post.id },
    props: post,
  }));
}
type Props = CollectionEntry<'notes'>;

const post = Astro.props;
const { Content, headings, remarkPluginFrontmatter } = await render(post);
---

<BlogPost
  post={post}
  headings={headings}
  minutesRead={remarkPluginFrontmatter.minutesRead}
  collection="notes"
>
  <Content components={{ Accordion, Def: Definition, CodeFilename, Playground }} />
</BlogPost>
