---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHero from '@/components/PageHero.astro';
import { ROUTES } from '@/constants/routes';
import { pageTitle } from '@/lib/seo';

const title = pageTitle('Page not found');
const description = 'The page you are looking for could not be found.';
---

<BaseLayout title={title} description={description} noindex>
  <div class="not-found">
    <PageHero title="Page not found">
      <p>{description}</p>
    </PageHero>
    <nav aria-label="Helpful links">
      <a class="link section-link" href={ROUTES.home}>Home</a>
      <a class="link section-link" href={ROUTES.writing}>Writing</a>
      <a class="link section-link" href={ROUTES.projects}>Projects</a>
    </nav>
  </div>
</BaseLayout>

<style>
  nav {
    display: flex;
    gap: 1rem;
  }
</style>
