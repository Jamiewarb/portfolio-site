---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHero from '@/components/PageHero.astro';
import HeroLinks from '@/components/HeroLinks.astro';
import WritingArchive from '@/components/WritingArchive.astro';
import { getPublishedBlogPosts } from '@/lib/blog';
import { ROUTES } from '@/constants/routes';
import { WRITING_DESCRIPTION, WRITING_TITLE } from '@/config/site';
import { collectionPageSchema, pageTitle } from '@/lib/seo';

const posts = await getPublishedBlogPosts();

const jsonLd = collectionPageSchema(Astro.site!, WRITING_TITLE, WRITING_DESCRIPTION);
---

<BaseLayout title={pageTitle(WRITING_TITLE)} description={WRITING_DESCRIPTION} jsonLd={jsonLd}>
  <PageHero title={WRITING_TITLE}>
    <p class="description">{WRITING_DESCRIPTION}</p>

    <HeroLinks links={[{ href: ROUTES.topics, label: 'See all topics' }]} />
  </PageHero>

  <WritingArchive posts={posts} />

  <style>
    @reference "../../styles/global.css";

    .description {
      margin: 0;
      max-width: 600px;

      @variant md {
        font-size: 1.325rem;
      }
    }
  </style>
</BaseLayout>
