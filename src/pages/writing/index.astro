---
import BookOpen from '@lucide/astro/icons/book-open';
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHero from '@/components/PageHero.astro';
import WritingArchive from '@/components/WritingArchive.astro';
import { getPublishedBlogPosts } from '@/lib/blog';
import { ROUTES } from '@/constants/routes';

const posts = await getPublishedBlogPosts();
---

<BaseLayout title="Writing">
  <PageHero title="Writing">
    <p class="description">
      Original articles, thoughts, and insights on engineering, leadership, and my life.
    </p>

    <a class="link topics-link" href={ROUTES.topics}>See all topics</a>
  </PageHero>

  <WritingArchive posts={posts} />
</BaseLayout>

<style>
  @reference "../../styles/global.css";

  .writing-eyebrow {
    display: inline-flex;
    margin: 0 0 0.75rem;
    color: var(--text-color);
  }

  .description {
    margin: 0;
    max-width: 600px;

    @variant md {
      font-size: 1.325rem;
    }
  }

  .topics-link {
    display: inline-block;
    margin-top: 1.5rem;
    margin-bottom: 1rem;
    font-size: 1.125rem;
  }
</style>
