---
import BaseLayout from '../layouts/BaseLayout.astro';
import { HOME_DESCRIPTION, HOME_TITLE } from '../config/site';
import PageHero from '../components/PageHero.astro';
import RecentWriting from '../components/RecentWriting.astro';
import { ROUTES } from '../constants/routes';
import { absoluteUrl, websiteSchema } from '../lib/seo';
import { Image } from 'astro:assets';
import headshot from '@/assets/jamie-warburton-headshot-software-engineering-leader.png';

const logoUrl = absoluteUrl('/favicon.svg', Astro.site!);
const jsonLd = websiteSchema(Astro.site!, logoUrl);
---

<BaseLayout title={HOME_TITLE} description={HOME_DESCRIPTION} jsonLd={jsonLd}>
  <PageHero type="index" title="I'm Jamie">
    <p class="description">
      I'm a software engineer, engineering leader, and proud father. I've been making websites
      and products since 2005, and some of them have won&nbsp;awards!
    </p>
    <p class="description">
      Here you'll find my writing, projects, talks, and other things I've been working on or
      involved in.
    </p>
    <p class="links">
      <a class="link" href={ROUTES.me}>About Me</a>
      <!--<a class="link" href={ROUTES.external.newsletter} rel="noreferrer" target="_blank">
        Email Newsletter
      </a>-->
    </p>

    <Image
      slot="image"
      src={headshot}
      alt="Jamie Warburton headshot"
      width={500}
      height={500}
      class="hero-image"
    />
  </PageHero>

  <div class="home-sections">
    <section>
      <h2>Recent Writing</h2>
      <RecentWriting limit={5} />
    </section>

    <section>
      <h2>Projects</h2>
      <p class="projects-empty">No projects yet.</p>
    </section>
  </div>
</BaseLayout>

<style>
  @reference "../styles/global.css";

  .description {
    margin: 0 0 1.25rem;
    max-width: 600px;

    @variant md {
      font-size: 1.325rem;
    }
  }

  .links {
    display: flex;
    gap: 1rem;
  }

  .link {
    font-size: 1.125rem;
  }

  .home-sections {
    display: grid;
    gap: 3rem;
    margin-bottom: 4rem;

    &:last-child {
      margin-bottom: 0;
    }

    @variant lg {
      grid-template-columns: 1fr 1fr;
      gap: var(--wrapper-padding);
      align-items: start;
    }
  }

  .home-sections section {
    margin: 0;
    min-width: 0;
  }

  h2 {
    margin: 0 0 1.25rem;
    font-size: 1.625rem;
    line-height: 1.15;

    @variant md {
      font-size: 1.875rem;
    }
  }

  .projects-empty {
    margin: 0;
    color: var(--text-muted);
  }
</style>
