---
import BaseLayout from '../layouts/BaseLayout.astro';
import { HOME_DESCRIPTION, HOME_TITLE } from '../config/site';
import PageHero from '../components/PageHero.astro';
import RecentWriting from '../components/RecentWriting.astro';
import RecentNotes from '../components/RecentNotes.astro';
import { ROUTES } from '../constants/routes';
import { absoluteUrl, websiteSchema } from '../lib/seo';
import { Image } from 'astro:assets';
import headshot from '@/assets/jamie-warburton-headshot-software-engineering-leader.png';

import { getPublishedBlogPosts } from '@/lib/blog';
import { getPublishedNotes } from '@/lib/notes';

const logoUrl = absoluteUrl('/favicon.svg', Astro.site!);
const jsonLd = websiteSchema(Astro.site!, logoUrl);

const recentPosts = await getPublishedBlogPosts({ limit: 5 });
const recentNotes = await getPublishedNotes({ limit: 5 });
const writingSectionStart = 6;
const writingListStart = 7;
const allWritingIndex = writingListStart + recentPosts.length;
const projectsSectionStart = allWritingIndex + 1;
const allProjectsIndex = projectsSectionStart + 2;
const notesSectionStart = allProjectsIndex + 1;
const notesListStart = notesSectionStart + 1;
const allNotesIndex = notesListStart + recentNotes.length;
---

<style is:inline>
  .home-page .fade-in {
    opacity: 0;
  }

  @media (prefers-reduced-motion: reduce) {
    .home-page .fade-in {
      opacity: 1;
    }
  }
</style>

<BaseLayout title={HOME_TITLE} description={HOME_DESCRIPTION} jsonLd={jsonLd}>
  <div class="home-page">
    <PageHero type="index" title="I'm Jamie">
      <p class="description fade-in" style="--load-index: 1">
        I'm a software engineer, engineering leader, and proud father. I've been making
        websites and products since 2005, and some of them have won&nbsp;awards!
      </p>
      <p class="description fade-in" style="--load-index: 2">
        Here you'll find my writing, projects, talks, and other things I've been working on or
        involved in.
      </p>
      <p class="links fade-in" style="--load-index: 3">
        <span>
          <a class="link" href={ROUTES.me}>About Me</a>
        </span>
        <!-- <span>
          <a class="link" href={ROUTES.external.newsletter} rel="noreferrer" target="_blank">
            Email Newsletter
          </a> 
        </span> -->
      </p>

      <div class="hero-image-wrap fade-in" style="--load-index: 4" slot="image">
        <Image
          src={headshot}
          alt="Jamie Warburton headshot"
          width={500}
          height={500}
          class="hero-image"
        />
      </div>
    </PageHero>

    <div class="home-sections">
      <section>
        <h2 class="fade-in" style={`--load-index: ${writingSectionStart}`}>Recent Writing</h2>
        <RecentWriting limit={5} loadIndexStart={writingListStart} />
        <span class="section-link fade-in" style={`--load-index: ${allWritingIndex}`}>
          <a class="link" href={ROUTES.writing}>All Writing</a>
        </span>
      </section>

      <section>
        <h2 class="fade-in" style={`--load-index: ${projectsSectionStart}`}>Projects</h2>
        <p class="projects-empty fade-in" style={`--load-index: ${projectsSectionStart + 1}`}>
          No projects yet.
        </p>
        <span class="section-link fade-in" style={`--load-index: ${allProjectsIndex}`}>
          <a class="link" href={ROUTES.projects}>All Projects</a>
        </span>
      </section>

      <section>
        <h2 class="fade-in" style={`--load-index: ${notesSectionStart}`}>Notes</h2>
        <RecentNotes limit={5} loadIndexStart={notesListStart} />
        <span class="section-link fade-in" style={`--load-index: ${allNotesIndex}`}>
          <a class="link" href={ROUTES.notes}>All Notes</a>
        </span>
      </section>
    </div>
  </div>
</BaseLayout>

<style>
  @reference "../styles/global.css";

  .description {
    margin: 0 0 1.25rem;
    max-width: 600px;

    @variant md {
      font-size: 1.325rem;
    }
  }

  .links {
    display: inline-flex;
    gap: 1rem;
  }

  .link {
    font-size: 1.125rem;
  }

  .home-sections {
    display: grid;
    gap: 3rem;
    margin-bottom: 4rem;

    &:last-child {
      margin-bottom: 0;
    }

    @variant lg {
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
      align-items: start;
    }
  }

  .home-sections section {
    margin: 0;
    min-width: 0;
  }

  h2 {
    margin: 0 0 1.25rem;
    font-size: 1.625rem;
    line-height: 1.15;

    @variant md {
      font-size: 1.875rem;
    }
  }

  .projects-empty {
    margin: 0;
    color: var(--text-muted);
  }

  .section-link {
    display: inline-block;
    margin-top: 1.25rem;
  }
</style>
