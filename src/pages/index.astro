---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../config/site';
import PageHero from '../components/PageHero.astro';
import RecentWriting from '../components/RecentWriting.astro';
import { ROUTES } from '../constants/routes';
---

<BaseLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
  <PageHero type="index" title="I'm Jamie">
    <p class="description">
      I'm a software engineer, engineering leader, and proud father. I've been making websites
      and products since 2010, and some of them have won&nbsp;awards!
    </p>
    <p class="description">
      Here you'll find my writing, projects, talks, and other things I've been working on or
      involved in.
    </p>
    <p class="links">
      <a class="link" href={ROUTES.me}>About Me</a>
      <a class="link" href={ROUTES.external.newsletter} rel="noreferrer" target="_blank">
        Email Newsletter
      </a>
    </p>
  </PageHero>

  <section>
    <h2>Recent Writing</h2>
    <RecentWriting limit={5} />
  </section>

  <section>
    <h2>Highlighted Projects</h2>
    <p class="projects-empty">No projects yet.</p>
  </section>
</BaseLayout>

<style>
  @reference "../styles/global.css";

  .description {
    margin: 0 0 1.25rem;
    max-width: 600px;

    @variant md {
      font-size: 1.325rem;
    }
  }

  .links {
    display: flex;
    gap: 1rem;
  }

  .link {
    font-size: 1.125rem;
  }

  section {
    margin-bottom: 4rem;
  }

  h2 {
    margin: 0 0 1.25rem;
    font-size: 1.625rem;
    line-height: 1.15;

    @variant md {
      font-size: 1.875rem;
    }
  }

  .projects-empty {
    margin: 0;
    color: var(--text-muted);
  }
</style>
