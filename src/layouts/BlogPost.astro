---
import { Image } from 'astro:assets';
import { articleDate, tagToSlug, type BlogPost } from '../lib/blog';
import type { MarkdownHeading } from 'astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import FormattedDate from '../components/FormattedDate.astro';
import ArticleComments from '../components/ArticleComments.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import PostHeartCounter from '../components/PostHeartCounter.astro';
import PostSidebar from '../components/PostSidebar.astro';
import Divider from '../components/Divider.astro';
import { ROUTES } from '../constants/routes';
import { SITE_AUTHOR } from '../config/site';
import { getArchivedLikeCount } from '../lib/likes/archived';
import {
  absoluteUrl,
  blogPostingSchema,
  breadcrumbSchema,
  normalizeJsonLd,
  pageTitle,
} from '../lib/seo';

interface Props {
  post: BlogPost;
  headings?: MarkdownHeading[];
  minutesRead?: string;
}

const {
  post,
  post: {
    id,
    data: {
      title,
      description,
      publishedAt,
      updatedAt,
      heroImage,
      ogTitle,
      ogDescription,
      ogImage,
      tags = [],
      author: postAuthor,
      postId,
    },
  },
  headings = [],
  minutesRead,
} = Astro.props;

const initialLikeCount = getArchivedLikeCount(postId);

const canonicalURL = absoluteUrl(ROUTES.writingPost(id), Astro.site!);
const logoUrl = absoluteUrl('/favicon.svg', Astro.site!);
const socialImage = ogImage ?? heroImage;
const imageUrl = socialImage ? new URL(socialImage.src, Astro.site).href : undefined;
const authorName = postAuthor ?? SITE_AUTHOR;
const modifiedTime = updatedAt ?? publishedAt;

const breadcrumbAncestors = [{ label: 'Writing', href: ROUTES.writing }];

const jsonLd = normalizeJsonLd([
  blogPostingSchema({
    title,
    description,
    publishedAt,
    updatedAt,
    imageUrl,
    url: canonicalURL,
    site: Astro.site!,
    authorName,
    logoUrl,
  }),
  breadcrumbSchema(
    [
      ...breadcrumbAncestors.map((item) => ({ name: item.label, path: item.href })),
      { name: title },
    ],
    Astro.site!,
  ),
]);
---

<BaseLayout
  title={pageTitle(title)}
  description={description}
  image={heroImage}
  ogTitle={ogTitle}
  ogDescription={ogDescription}
  ogImage={ogImage}
  ogType="article"
  publishedTime={publishedAt}
  modifiedTime={modifiedTime}
  author={authorName}
  jsonLd={jsonLd}
  pageType="article"
>
  <article>
    <Breadcrumbs items={breadcrumbAncestors} pageTitle={title} pageTitleVariant="article" />

    <div class="mb-4 flex flex-col">
      <div class="post-meta">
        <div class="eyebrow-meta">
          <div class="date">
            <FormattedDate date={articleDate(post)} />
          </div>
          {
            minutesRead && (
              <>
                <Divider />
                <span class="reading-time">{minutesRead}</span>
              </>
            )
          }
          <Divider />
          <a href="#comments" class="comments-link">Comments</a>
        </div>

        {
          tags.length > 0 && (
            <ul class="topic-tags">
              {tags.map((tag) => (
                <li>
                  <a class="topic-tag" href={ROUTES.topic(tagToSlug(tag))}>
                    {tag}
                  </a>
                </li>
              ))}
            </ul>
          )
        }
      </div>

      {postId && <PostHeartCounter postId={postId} initialCount={initialLikeCount} />}
    </div>

    <div class="flex flex-col gap-6">
      {
        heroImage && (
          <div class="hero-image">
            <Image width={1020} height={510} src={heroImage} alt={title} />
          </div>
        )
      }

      <div class="main-article">
        <div class="prose dark:prose-invert">
          <div class="introduction" id="introduction"></div>
          <slot />
        </div>
      </div>
    </div>

    <ArticleComments />
  </article>

  <PostSidebar slot="post-sidebar" headings={headings} />
</BaseLayout>

<style>
  .post-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1rem;
    font-size: 0.9rem;
  }

  .post-meta-start {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.5rem;
    flex-shrink: 0;
  }

  .eyebrow-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-shrink: 0;
  }

  .topic-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    justify-content: flex-end;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .topic-tag {
    border: 2px solid var(--content-border-color);
    border-radius: var(--border-radius);
    padding: 0.15rem 0.5rem;
    color: inherit;
    font-size: 0.8rem;
    font-weight: 600;
    line-height: 1.2;
    text-decoration: none;
    white-space: nowrap;
  }

  .topic-tag:hover,
  .topic-tag:focus-visible {
    background-color: var(--link-highlight-color);
    text-decoration: none;
  }

  .date,
  .reading-time {
    color: var(--text-muted);
  }

  .comments-link {
    color: var(--link-color);
    font-weight: 500;
  }
</style>
