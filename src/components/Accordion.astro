---
interface Props {
  title?: string;
  defaultOpen?: boolean;
}

const { title = 'View code', defaultOpen = false } = Astro.props;
const panelId = `accordion-panel-${crypto.randomUUID()}`;
---

<div class="accordion" data-accordion data-default-open={defaultOpen || undefined}>
  <button
    type="button"
    class="accordion__trigger"
    aria-expanded={defaultOpen}
    aria-controls={panelId}
    data-accordion-trigger
  >
    <span class="accordion__title">{title}</span>
    <span class="accordion__chevron" aria-hidden="true"></span>
  </button>
  <div class="accordion__panel" id={panelId} data-accordion-panel>
    <div class="accordion__content">
      <slot />
    </div>
  </div>
</div>

<style>
  .accordion {
    margin-block: 1.5rem;
    border: 1px solid var(--content-border-color);
    border-radius: var(--border-radius);
    background: var(--bg-color);
  }

  .accordion__trigger {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    width: 100%;
    padding: 0.75rem 1rem;
    border: none;
    border-radius: var(--border-radius);
    background: transparent;
    color: var(--heading-color);
    font-family: var(--font-sans);
    font-size: 0.95rem;
    font-weight: 600;
    text-align: left;
    cursor: pointer;
    transition: background-color 0.15s ease;
  }

  .accordion__trigger:hover {
    background: var(--toc-link-hover-bg);
  }

  .accordion__trigger:focus-visible {
    outline: 2px solid var(--link-color);
    outline-offset: -2px;
  }

  .accordion__chevron {
    flex-shrink: 0;
    width: 0.5rem;
    height: 0.5rem;
    border-right: 2px solid currentColor;
    border-bottom: 2px solid currentColor;
    transform: rotate(45deg);
    transition: transform 0.35s cubic-bezier(0.5, 0, 0.1, 1);
  }

  .accordion.is-open .accordion__chevron {
    transform: rotate(-135deg);
  }

  .accordion__panel {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.35s cubic-bezier(0.5, 0, 0.1, 1);
  }

  .accordion.is-open .accordion__panel {
    grid-template-rows: 1fr;
  }

  .accordion__content {
    overflow: hidden;
    min-height: 0;
    padding-inline: 1rem;
  }

  .accordion.is-open .accordion__content {
    padding-bottom: 1rem;
  }

  @media (prefers-reduced-motion: reduce) {
    .accordion__panel,
    .accordion__chevron {
      transition: none;
    }
  }
</style>

<script>
  function setupAccordions() {
    for (const accordion of document.querySelectorAll<HTMLElement>('[data-accordion]')) {
      if (accordion.dataset.accordionInit) continue;
      accordion.dataset.accordionInit = 'true';

      const trigger = accordion.querySelector<HTMLButtonElement>('[data-accordion-trigger]');
      const panel = accordion.querySelector<HTMLElement>('[data-accordion-panel]');
      if (!trigger || !panel) continue;

      const defaultOpen = accordion.dataset.defaultOpen !== undefined;

      function setOpen(open: boolean) {
        accordion.classList.toggle('is-open', open);
        trigger!.setAttribute('aria-expanded', String(open));
      }

      setOpen(defaultOpen);

      trigger.addEventListener('click', () => {
        setOpen(!accordion.classList.contains('is-open'));
      });
    }
  }

  setupAccordions();
  document.addEventListener('astro:page-load', setupAccordions);
</script>
