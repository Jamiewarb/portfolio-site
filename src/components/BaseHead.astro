---
import '@/styles/global.css';
import { Font } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import JsonLd from '@/components/JsonLd.astro';
import { DEFAULT_OG_IMAGE, SITE_LOCALE, SITE_TITLE, TWITTER_HANDLE } from '@/config/site';
import type { JsonLdSchema } from '@/lib/seo';

interface Props {
  title: string;
  description: string;
  image?: ImageMetadata;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: ImageMetadata;
  ogType?: 'website' | 'article';
  publishedTime?: Date;
  modifiedTime?: Date;
  author?: string;
  noindex?: boolean;
  jsonLd?: JsonLdSchema;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const {
  title,
  description,
  image = DEFAULT_OG_IMAGE,
  ogTitle,
  ogDescription,
  ogImage,
  ogType = 'website',
  publishedTime,
  modifiedTime,
  author,
  noindex = false,
  jsonLd,
} = Astro.props;

const socialTitle = ogTitle ?? title;
const socialDescription = ogDescription ?? description;
const socialImage = ogImage ?? image;
const socialImageUrl = new URL(socialImage.src, Astro.site);
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<script is:inline>
  (function () {
    const theme = localStorage.getItem('theme') || 'system';
    const dark =
      theme === 'dark' ||
      (theme === 'system' && window.matchMedia('(prefers-color-scheme: dark)').matches);
    if (dark) document.documentElement.classList.add('dark');
    document.documentElement.dataset.theme = theme;
  })();
</script>
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="sitemap" href="/sitemap-index.xml" />
<link
  rel="alternate"
  type="application/rss+xml"
  title={SITE_TITLE}
  href={new URL('rss.xml', Astro.site)}
/>
<meta name="generator" content={Astro.generator} />
{noindex && <meta name="robots" content="noindex" />}

<Font cssVariable="--font-rammetto-one" preload />

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />
{author && <meta name="author" content={author} />}

<!-- Open Graph -->
<meta property="og:type" content={ogType} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:site_name" content={SITE_TITLE} />
<meta property="og:locale" content={SITE_LOCALE} />
<meta property="og:title" content={socialTitle} />
<meta property="og:description" content={socialDescription} />
<meta property="og:image" content={socialImageUrl} />
<meta property="og:image:width" content={String(socialImage.width)} />
<meta property="og:image:height" content={String(socialImage.height)} />
{
  ogType === 'article' && publishedTime && (
    <meta property="article:published_time" content={publishedTime.toISOString()} />
  )
}
{
  ogType === 'article' && modifiedTime && (
    <meta property="article:modified_time" content={modifiedTime.toISOString()} />
  )
}
{ogType === 'article' && author && <meta property="article:author" content={author} />}

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:url" content={canonicalURL} />
<meta name="twitter:title" content={socialTitle} />
<meta name="twitter:description" content={socialDescription} />
<meta name="twitter:image" content={socialImageUrl} />
<meta name="twitter:site" content={TWITTER_HANDLE} />
<meta name="twitter:creator" content={TWITTER_HANDLE} />

{jsonLd && <JsonLd schema={jsonLd} />}
