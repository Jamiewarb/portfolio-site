---
import BookOpen from "@lucide/astro/icons/book-open";
import CircleUser from "@lucide/astro/icons/circle-user";
import FolderKanban from "@lucide/astro/icons/folder-kanban";
import StickyNote from "@lucide/astro/icons/sticky-note";
import { GITHUB_URL, LINKEDIN_URL } from "../config/site";
import ThemeToggle from "./ThemeToggle.astro";

const iconProps = {
  size: 16,
  "stroke-width": 2,
  class: "sidebar-nav-icon",
  "aria-hidden": true,
} as const;
---

<header class="navbar lg:hidden">
  <div><ThemeToggle /></div>
  <div><a href="/"><span class="heading">Jamie Warburton</span></a></div>
</header>

<aside class="sidebar hidden lg:block">
  <div class="sidebar-main">
    <div class="sidebar-section">
      <a href="/"><span class="sidebar-identity heading">Jamie Warburton</span></a>
    </div>

    <section class="sidebar-section">
      <h2>About Me</h2>
      <div class="sidebar-content">
        <p>
          I'm <a href="/me/" class="link">Jamie</a>, a software engineer and
          engineering leader. This is where I share my thoughts and experiences.
        </p>
      </div>
    </section>

    <section class="sidebar-section">
      <nav class="sidebar-nav-links">
        <a href="/writing/">
          <BookOpen {...iconProps} />
          <span>Writing</span>
        </a>
        <a href="/notes/">
          <StickyNote {...iconProps} />
          <span>Notes</span>
        </a>
        <a href="/projects/">
          <FolderKanban {...iconProps} />
          <span>Projects</span>
        </a>
        <a href="/me/">
          <CircleUser {...iconProps} />
          <span>About Me</span>
        </a>
      </nav>
    </section>



    <section class="sidebar-section">
      <h2>Get Updates</h2>
      <div class="sidebar-links">
        <a href="https://jamiewarb.substack.com/" target="_blank" rel="noreferrer">
          <span>Newsletter</span>
        </a>
        <a href="/rss.xml" target="_blank" rel="noreferrer">
          <span>RSS Feed</span>
        </a>
      </div>
    </section>
  </div>

  <div class="sidebar-footer">
    <nav class="sidebar-social-links" aria-label="Social links">
      <a
        href={GITHUB_URL}
        target="_blank"
        rel="me noopener noreferrer"
        aria-label="GitHub"
      >
        <svg
          class="sidebar-nav-icon"
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path
            d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-.88.28-1.5 0-2.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"
          ></path>
          <path d="M9 18c-4.51 2-5-2-7-2"></path>
        </svg>
      </a>
      <a
        href={LINKEDIN_URL}
        target="_blank"
        rel="me noopener noreferrer"
        aria-label="LinkedIn"
      >
        <svg
          class="sidebar-nav-icon"
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"
          ></path>
          <rect width="4" height="12" x="2" y="9"></rect>
          <circle cx="4" cy="4" r="2"></circle>
        </svg>
      </a>
    </nav>
    <ThemeToggle />
  </div>
</aside>

<style>
  .sidebar {
    background: var(--sidebar-bg-color);
    border-right: 1px solid var(--sidebar-border-color);
    display: flex;
    flex-direction: column;
    height: 100vh;
    min-width: var(--sidebar-width);
    position: sticky;
    top: 0;
    width: var(--sidebar-width);
  }

  .sidebar-main {
    flex: 1;
    min-height: 0;
    overflow-y: auto;
    scrollbar-width: thin;
  }

  .sidebar-section {
    border-bottom: 1px solid var(--sidebar-border-color);
    margin: 1.25rem;
    padding-bottom: 1.5rem;

    &:last-child {
      border: none;
      padding-bottom: 3rem;
    }
  }

  .sidebar-section h2 {
    font-size: 1.125rem;
    margin-bottom: 0.75rem;
    margin-top: 0;
  }

  .sidebar-content > p:last-child {
    margin-bottom: 0;
  }

  .sidebar-content p {
    font-size: 1.0625rem;
  }

  .sidebar-identity {
    font-size: 1.625rem;

    &:hover {
      text-decoration: underline;
      text-decoration-color: var(--color-text);
      text-decoration-style: dotted;
      text-decoration-thickness: 2px;
      text-underline-offset: 4px;
    }
  }

  .sidebar-nav-links {
    display: flex;
    flex-direction: column;
    gap: 2px;

    a {
      align-items: center;
      border-radius: var(--border-radius);
      color: var(--color-text);
      display: flex;
      font-size: 1.125rem;
      font-weight: 500;
      gap: 0.5rem;
      margin-left: -.5rem;
      margin-right: -.5rem;
      padding: 4px .5rem;

      &:hover {
        background-color: var(--link-highlight-color);
        text-decoration: none;
      }
    }
  }

  .sidebar-nav-icon {
    flex-shrink: 0;
  }

  .sidebar-links {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;

    a {
      font-size: 1.125rem;
    }
  }

  .sidebar-social-links {
    display: flex;
    gap: 0.25rem;
    margin-left: -0.5rem;

    a {
      align-items: center;
      border-radius: var(--border-radius);
      color: var(--color-text);
      display: flex;
      padding: 4px 0.5rem;

      &:hover {
        background-color: var(--link-highlight-color);
        text-decoration: none;
      }
    }
  }

  .sidebar-footer {
    align-items: center;
    border-top: 1px solid var(--sidebar-border-color);
    display: flex;
    flex-shrink: 0;
    justify-content: space-between;
    margin: 0 1.25rem;
    padding: 1.25rem 0 1.5rem;
  }
</style>
