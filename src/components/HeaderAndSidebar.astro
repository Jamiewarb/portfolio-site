---
import BookOpen from '@lucide/astro/icons/book-open';
import CircleUser from '@lucide/astro/icons/circle-user';
import FolderKanban from '@lucide/astro/icons/folder-kanban';
import Menu from '@lucide/astro/icons/menu';
import StickyNote from '@lucide/astro/icons/sticky-note';
import X from '@lucide/astro/icons/x';
import { ROUTES } from '../constants/routes';
import { SocialLink } from './social/SocialLink';
import ThemeToggle from './ThemeToggle.astro';

const iconProps = {
  size: 16,
  'stroke-width': 2,
  class: 'sidebar-nav-icon',
  'aria-hidden': true,
} as const;

const navLinks = [
  { href: ROUTES.writing, label: 'Writing', Icon: BookOpen },
  { href: ROUTES.notes, label: 'Notes', Icon: StickyNote },
  { href: ROUTES.projects, label: 'Projects', Icon: FolderKanban },
  { href: ROUTES.me, label: 'About Me', Icon: CircleUser },
] as const;

const currentPath = Astro.url.pathname;

function isActive(href: string) {
  if (href === ROUTES.home) {
    return currentPath === '/';
  }

  return currentPath.startsWith(href);
}
---

<header class="navbar lg:hidden">
  <div class="navbar-title">
    <a href={ROUTES.home} class="navbar-title-link">
      <span class="heading">Jamie Warburton</span>
    </a>
  </div>

  <div class="navbar-container">
    <section class="navbar-section">
      <button
        type="button"
        class="navbar-button nav-menu-button"
        data-nav-menu-button
        aria-expanded="false"
        aria-controls="nav-menu"
        aria-label="Toggle navigation menu"
      >
        <Menu class="nav-menu-icon" size={24} stroke-width={2} aria-hidden="true" />
        <X class="nav-close-icon" size={24} stroke-width={2} aria-hidden="true" />
      </button>

      <nav
        id="nav-menu"
        class="navbar-menu nav-items"
        data-nav-menu
        aria-label="Main navigation"
      >
        {
          navLinks.map(({ href, label, Icon }) => (
            <a href={href} class:list={[{ active: isActive(href) }]} data-nav-link>
              <Icon {...iconProps} />
              {label}
            </a>
          ))
        }
      </nav>

      <div class="navbar-menu social">
        <ThemeToggle />
      </div>
    </section>
  </div>
</header>

<aside class="sidebar hidden lg:block">
  <div class="sidebar-main">
    <div class="sidebar-section">
      <a href={ROUTES.home}><span class="sidebar-identity heading">Jamie Warburton</span></a>
    </div>

    <section class="sidebar-section">
      <div class="sidebar-content">
        <p>
          I'm <a href={ROUTES.me} class="link">Jamie</a>, a software engineer, currently
          building websites for non-profits at <a
            href="https://www.hexdigital.com.com"
            target="_blank"
            rel="noreferrer"
            class="link">Hex Digital</a
          >.
        </p>
      </div>
    </section>

    <section class="sidebar-section">
      <nav class="sidebar-nav-links">
        {
          navLinks.map(({ href, label, Icon }) => (
            <a href={href} class:list={[{ active: isActive(href) }]}>
              <Icon {...iconProps} />
              <span>{label}</span>
            </a>
          ))
        }
      </nav>
    </section>
  </div>

  <div class="sidebar-footer">
    <nav class="sidebar-social-links" aria-label="Social links">
      <SocialLink client:load href={ROUTES.external.github} label="GitHub" platform="github" />
      <SocialLink
        client:load
        href={ROUTES.external.linkedin}
        label="LinkedIn"
        platform="linkedin"
      />
    </nav>
    <ThemeToggle />
  </div>
</aside>

<style>
  @reference "../styles/global.css";

  .navbar {
    align-items: center;
    background: var(--sidebar-bg-color);
    border-bottom: 1px solid var(--sidebar-border-color);
    display: flex;
    gap: 1rem;
    height: var(--navbar-height);
    justify-content: space-between;
    left: 0;
    padding: 0 0.7rem 0 var(--wrapper-padding);
    position: fixed;
    top: 0;
    width: 100%;
    z-index: 10;

    @variant lg {
      display: none;
    }
  }

  .navbar-title {
    align-items: center;
    display: flex;
    height: var(--navbar-height);
    z-index: 3;
  }

  .navbar-title-link {
    align-items: center;
    color: var(--text-color);
    display: flex;
    font-weight: 600;
    gap: 0.75rem;
    text-decoration: none;
    white-space: nowrap;
  }

  .navbar-container {
    align-items: center;
    display: flex;
    height: var(--navbar-height);
    justify-content: flex-end;
    width: 100%;
  }

  .navbar-section {
    align-items: center;
    display: flex;
    gap: 0.25rem;
  }

  .navbar-menu {
    align-items: center;
    display: flex;
    gap: 0.5rem;

    a {
      align-items: center;
      border-radius: var(--border-radius);
      color: var(--text-muted);
      display: flex;
      font-weight: 500;
      gap: 0.5rem;
      padding: 0.75rem 1rem;
      text-decoration: none;
      white-space: nowrap;

      &:hover {
        background: var(--link-highlight-color);
      }

      &.active {
        background: var(--link-highlight-color);
        color: var(--text-color);
      }
    }

    &.social {
      gap: 2px;
    }

    &.nav-items {
      display: none;
    }
  }

  .navbar-button {
    align-items: center;
    background: transparent;
    border: 1px solid transparent;
    border-radius: var(--border-radius);
    box-shadow: none;
    color: var(--text-muted);
    cursor: pointer;
    display: flex;
    height: 38px;
    justify-content: center;
    padding: 0.5rem;
    text-decoration: none;
    width: 38px;

    &:hover {
      background: var(--link-highlight-color);
      border-color: transparent;
      color: var(--text-color);
    }
  }

  .nav-menu-button .nav-close-icon {
    display: none;
  }

  .nav-menu-button.active {
    background: var(--link-highlight-color);
    border-color: var(--link-color);
    box-shadow: 0 0 0 1px var(--link-color);
    color: var(--link-color);
  }

  .nav-menu-button.active .nav-menu-icon {
    display: none;
  }

  .nav-menu-button.active .nav-close-icon {
    display: block;
  }

  .navbar-menu.nav-items.active {
    @variant max-md {
      background: var(--sidebar-bg-color);
      box-shadow: 0 10px 15px rgb(0 0 0 / 20%);
      display: flex;
      flex-direction: column;
      height: calc(100vh - var(--navbar-height));
      justify-content: center;
      left: 0;
      margin-top: var(--navbar-height);
      padding-bottom: 40vh;
      position: fixed;
      top: 0;
      width: 100%;
      z-index: 2;

      a {
        align-items: center;
        display: flex;
        font-size: 1.2rem;
        gap: 0.5rem;
      }
    }
  }

  .nav-menu-button {
    @variant md {
      display: none;
    }
  }

  .navbar-section {
    @variant md {
      gap: 1rem;
    }
  }

  .navbar-menu.nav-items {
    @variant md {
      display: flex !important;

      a {
        padding: 0.5rem 0.75rem;
      }
    }
  }

  .sidebar {
    background: var(--sidebar-bg-color);
    border-right: 1px solid var(--sidebar-border-color);
    flex-direction: column;
    height: 100vh;
    min-width: var(--sidebar-width);
    position: sticky;
    top: 0;
    width: var(--sidebar-width);

    @variant lg {
      display: flex;
    }
  }

  .sidebar-main {
    flex: 1;
    min-height: 0;
    overflow-y: auto;
    scrollbar-width: thin;
  }

  .sidebar-section {
    border-bottom: 1px solid var(--sidebar-border-color);
    margin: 1.25rem;
    padding-bottom: 1.5rem;

    &:last-child {
      border: none;
      padding-bottom: 3rem;
    }
  }

  .sidebar-section h2 {
    font-size: 1.125rem;
    margin-bottom: 0.75rem;
    margin-top: 0;
  }

  .sidebar-content > p:last-child {
    margin-bottom: 0;
  }

  .sidebar-content p {
    font-size: 1.0625rem;
  }

  .sidebar-identity {
    font-size: 1.625rem;

    &:hover {
      text-decoration: underline;
      text-decoration-color: var(--color-text);
      text-decoration-style: dotted;
      text-decoration-thickness: 2px;
      text-underline-offset: 4px;
    }
  }

  .sidebar-nav-links {
    display: flex;
    flex-direction: column;
    gap: 2px;

    a {
      align-items: center;
      border-radius: var(--border-radius);
      color: var(--color-text);
      display: flex;
      font-size: 1.125rem;
      font-weight: 500;
      gap: 0.5rem;
      margin-left: -0.5rem;
      margin-right: -0.5rem;
      padding: 4px 0.5rem;

      &:hover,
      &.active {
        background-color: var(--link-highlight-color);
        text-decoration: none;
      }
    }
  }

  .sidebar-nav-icon {
    flex-shrink: 0;
  }

  .sidebar-links {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;

    a {
      font-size: 1rem;
    }
  }

  .sidebar-social-links {
    display: flex;
    gap: 0.25rem;
    margin-left: -0.25rem;
  }

  .sidebar-footer {
    align-items: center;
    border-top: 1px solid var(--sidebar-border-color);
    display: flex;
    flex-shrink: 0;
    justify-content: space-between;
    margin: 0 1.25rem;
    padding: 1.25rem 0 1.5rem;
  }
</style>

<script>
  function setupMobileNav() {
    const button = document.querySelector<HTMLButtonElement>('[data-nav-menu-button]');
    const menu = document.querySelector<HTMLElement>('[data-nav-menu]');

    if (!button || !menu) {
      return;
    }

    const closeMenu = () => {
      button.classList.remove('active');
      menu.classList.remove('active');
      button.setAttribute('aria-expanded', 'false');
    };

    const openMenu = () => {
      button.classList.add('active');
      menu.classList.add('active');
      button.setAttribute('aria-expanded', 'true');
    };

    button.addEventListener('click', () => {
      if (menu.classList.contains('active')) {
        closeMenu();
      } else {
        openMenu();
      }
    });

    menu.querySelectorAll('[data-nav-link]').forEach((link) => {
      link.addEventListener('click', closeMenu);
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') {
        closeMenu();
      }
    });
  }

  setupMobileNav();
  document.addEventListener('astro:page-load', setupMobileNav);
</script>
