---
import BookOpen from '@lucide/astro/icons/book-open';
import CircleUser from '@lucide/astro/icons/circle-user';
import FolderKanban from '@lucide/astro/icons/folder-kanban';
import Menu from '@lucide/astro/icons/menu';
import StickyNote from '@lucide/astro/icons/sticky-note';
import X from '@lucide/astro/icons/x';
import { ROUTES } from '../constants/routes';
import ThemeToggle from './ThemeToggle.astro';

const iconProps = {
  size: 16,
  'stroke-width': 2,
  class: 'sidebar-nav-icon',
  'aria-hidden': true,
} as const;

const navLinks = [
  { href: ROUTES.writing, label: 'Writing', Icon: BookOpen },
  { href: ROUTES.notes, label: 'Notes', Icon: StickyNote },
  { href: ROUTES.projects, label: 'Projects', Icon: FolderKanban },
  { href: ROUTES.me, label: 'About Me', Icon: CircleUser },
] as const;

const currentPath = Astro.url.pathname;

function isActive(href: string) {
  if (href === ROUTES.home) {
    return currentPath === '/';
  }

  return currentPath.startsWith(href);
}
---

<header class="navbar lg:hidden">
  <div class="navbar-title">
    <a href={ROUTES.home} class="navbar-title-link">
      <span class="heading">Jamie Warburton</span>
    </a>
  </div>

  <div class="navbar-container">
    <section class="navbar-section">
      <button
        type="button"
        class="navbar-button nav-menu-button"
        data-nav-menu-button
        aria-expanded="false"
        aria-controls="nav-menu"
        aria-label="Toggle navigation menu"
      >
        <Menu class="nav-menu-icon" size={24} stroke-width={2} aria-hidden="true" />
        <X class="nav-close-icon" size={24} stroke-width={2} aria-hidden="true" />
      </button>

      <nav
        id="nav-menu"
        class="navbar-menu nav-items"
        data-nav-menu
        aria-label="Main navigation"
      >
        {
          navLinks.map(({ href, label, Icon }) => (
            <a href={href} class:list={[{ active: isActive(href) }]} data-nav-link>
              <Icon {...iconProps} />
              {label}
            </a>
          ))
        }
      </nav>

      <nav class="navbar-menu social" aria-label="Site settings and social links">
        <ThemeToggle />
        <a
          href={ROUTES.external.github}
          target="_blank"
          rel="me noopener noreferrer"
          class="navbar-button"
          aria-label="GitHub"
        >
          <svg
            class="sidebar-nav-icon"
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path
              d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-.88.28-1.5 0-2.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"
            ></path>
            <path d="M9 18c-4.51 2-5-2-7-2"></path>
          </svg>
        </a>
        <a
          href={ROUTES.external.linkedin}
          target="_blank"
          rel="me noopener noreferrer"
          class="navbar-button"
          aria-label="LinkedIn"
        >
          <svg
            class="sidebar-nav-icon"
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path
              d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"
            ></path>
            <rect width="4" height="12" x="2" y="9"></rect>
            <circle cx="4" cy="4" r="2"></circle>
          </svg>
        </a>
      </nav>
    </section>
  </div>
</header>

<aside class="sidebar hidden lg:block">
  <div class="sidebar-main">
    <div class="sidebar-section">
      <a href={ROUTES.home}><span class="sidebar-identity heading">Jamie Warburton</span></a>
    </div>

    <section class="sidebar-section">
      <div class="sidebar-content">
        <p>
          I'm <a href={ROUTES.me} class="link">Jamie</a>, a software engineer and father.
        </p>
      </div>
    </section>

    <section class="sidebar-section">
      <nav class="sidebar-nav-links">
        {
          navLinks.map(({ href, label, Icon }) => (
            <a href={href} class:list={[{ active: isActive(href) }]}>
              <Icon {...iconProps} />
              <span>{label}</span>
            </a>
          ))
        }
      </nav>
    </section>

    <section class="sidebar-section">
      <h2>Get Updates</h2>
      <div class="sidebar-links">
        <a href={ROUTES.external.newsletter} target="_blank" rel="noreferrer">
          <span>Newsletter</span>
        </a>
        <a href={ROUTES.rss} target="_blank" rel="noreferrer">
          <span>RSS Feed</span>
        </a>
      </div>
    </section>
  </div>

  <div class="sidebar-footer">
    <nav class="sidebar-social-links" aria-label="Social links">
      <a
        href={ROUTES.external.github}
        target="_blank"
        rel="me noopener noreferrer"
        aria-label="GitHub"
      >
        <svg
          class="sidebar-nav-icon"
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path
            d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-.88.28-1.5 0-2.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"
          ></path>
          <path d="M9 18c-4.51 2-5-2-7-2"></path>
        </svg>
      </a>
      <a
        href={ROUTES.external.linkedin}
        target="_blank"
        rel="me noopener noreferrer"
        aria-label="LinkedIn"
      >
        <svg
          class="sidebar-nav-icon"
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path
            d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"
          ></path>
          <rect width="4" height="12" x="2" y="9"></rect>
          <circle cx="4" cy="4" r="2"></circle>
        </svg>
      </a>
    </nav>
    <ThemeToggle />
  </div>
</aside>

<style>
  @reference "../styles/global.css";

  .navbar {
    align-items: center;
    background: var(--sidebar-bg-color);
    border-bottom: 1px solid var(--sidebar-border-color);
    display: flex;
    gap: 1rem;
    height: var(--navbar-height);
    justify-content: space-between;
    left: 0;
    padding: 0 0.7rem 0 var(--wrapper-padding);
    position: fixed;
    top: 0;
    width: 100%;
    z-index: 10;

    @variant lg {
      display: none;
    }
  }

  .navbar-title {
    align-items: center;
    display: flex;
    height: var(--navbar-height);
    z-index: 3;
  }

  .navbar-title-link {
    align-items: center;
    color: var(--text-color);
    display: flex;
    font-weight: 600;
    gap: 0.75rem;
    text-decoration: none;
    white-space: nowrap;
  }

  .navbar-container {
    align-items: center;
    display: flex;
    height: var(--navbar-height);
    justify-content: flex-end;
    width: 100%;
  }

  .navbar-section {
    align-items: center;
    display: flex;
    gap: 0.25rem;
  }

  .navbar-menu {
    align-items: center;
    display: flex;
    gap: 0.5rem;

    a {
      align-items: center;
      border-radius: var(--border-radius);
      color: var(--text-muted);
      display: flex;
      font-weight: 500;
      gap: 0.5rem;
      padding: 0.75rem 1rem;
      text-decoration: none;
      white-space: nowrap;

      &:hover {
        background: var(--link-highlight-color);
      }

      &.active {
        background: var(--link-highlight-color);
        color: var(--text-color);
      }
    }

    &.social {
      gap: 2px;
    }

    &.nav-items {
      display: none;
    }
  }

  .navbar-button {
    align-items: center;
    background: transparent;
    border: 1px solid transparent;
    border-radius: var(--border-radius);
    box-shadow: none;
    color: var(--text-muted);
    cursor: pointer;
    display: flex;
    height: 38px;
    justify-content: center;
    padding: 0.5rem;
    text-decoration: none;
    width: 38px;

    &:hover {
      background: var(--link-highlight-color);
      border-color: transparent;
      color: var(--text-color);
    }
  }

  .nav-menu-button .nav-close-icon {
    display: none;
  }

  .nav-menu-button.active {
    background: var(--link-highlight-color);
    border-color: var(--link-color);
    box-shadow: 0 0 0 1px var(--link-color);
    color: var(--link-color);
  }

  .nav-menu-button.active .nav-menu-icon {
    display: none;
  }

  .nav-menu-button.active .nav-close-icon {
    display: block;
  }

  .navbar-menu.nav-items.active {
    @variant max-md {
      background: var(--sidebar-bg-color);
      box-shadow: 0 10px 15px rgb(0 0 0 / 20%);
      display: flex;
      flex-direction: column;
      height: calc(100vh - var(--navbar-height));
      justify-content: center;
      left: 0;
      margin-top: var(--navbar-height);
      padding-bottom: 40vh;
      position: fixed;
      top: 0;
      width: 100%;
      z-index: 2;

      a {
        align-items: center;
        display: flex;
        font-size: 1.2rem;
        gap: 0.5rem;
      }
    }
  }

  .nav-menu-button {
    @variant md {
      display: none;
    }
  }

  .navbar-section {
    @variant md {
      gap: 1rem;
    }
  }

  .navbar-menu.nav-items {
    @variant md {
      display: flex !important;

      a {
        padding: 0.5rem 0.75rem;
      }
    }
  }

  .sidebar {
    background: var(--sidebar-bg-color);
    border-right: 1px solid var(--sidebar-border-color);
    flex-direction: column;
    height: 100vh;
    min-width: var(--sidebar-width);
    position: sticky;
    top: 0;
    width: var(--sidebar-width);

    @variant lg {
      display: flex;
    }
  }

  .sidebar-main {
    flex: 1;
    min-height: 0;
    overflow-y: auto;
    scrollbar-width: thin;
  }

  .sidebar-section {
    border-bottom: 1px solid var(--sidebar-border-color);
    margin: 1.25rem;
    padding-bottom: 1.5rem;

    &:last-child {
      border: none;
      padding-bottom: 3rem;
    }
  }

  .sidebar-section h2 {
    font-size: 1.125rem;
    margin-bottom: 0.75rem;
    margin-top: 0;
  }

  .sidebar-content > p:last-child {
    margin-bottom: 0;
  }

  .sidebar-content p {
    font-size: 1.0625rem;
  }

  .sidebar-identity {
    font-size: 1.625rem;

    &:hover {
      text-decoration: underline;
      text-decoration-color: var(--color-text);
      text-decoration-style: dotted;
      text-decoration-thickness: 2px;
      text-underline-offset: 4px;
    }
  }

  .sidebar-nav-links {
    display: flex;
    flex-direction: column;
    gap: 2px;

    a {
      align-items: center;
      border-radius: var(--border-radius);
      color: var(--color-text);
      display: flex;
      font-size: 1.125rem;
      font-weight: 500;
      gap: 0.5rem;
      margin-left: -0.5rem;
      margin-right: -0.5rem;
      padding: 4px 0.5rem;

      &:hover,
      &.active {
        background-color: var(--link-highlight-color);
        text-decoration: none;
      }
    }
  }

  .sidebar-nav-icon {
    flex-shrink: 0;
  }

  .sidebar-links {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;

    a {
      font-size: 1.125rem;
    }
  }

  .sidebar-social-links {
    display: flex;
    gap: 0.25rem;
    margin-left: -0.5rem;

    a {
      align-items: center;
      border-radius: var(--border-radius);
      color: var(--color-text);
      display: flex;
      padding: 4px 0.5rem;

      &:hover {
        background-color: var(--link-highlight-color);
        text-decoration: none;
      }
    }
  }

  .sidebar-footer {
    align-items: center;
    border-top: 1px solid var(--sidebar-border-color);
    display: flex;
    flex-shrink: 0;
    justify-content: space-between;
    margin: 0 1.25rem;
    padding: 1.25rem 0 1.5rem;
  }
</style>

<script>
  function setupMobileNav() {
    const button = document.querySelector<HTMLButtonElement>('[data-nav-menu-button]');
    const menu = document.querySelector<HTMLElement>('[data-nav-menu]');

    if (!button || !menu) {
      return;
    }

    const closeMenu = () => {
      button.classList.remove('active');
      menu.classList.remove('active');
      button.setAttribute('aria-expanded', 'false');
    };

    const openMenu = () => {
      button.classList.add('active');
      menu.classList.add('active');
      button.setAttribute('aria-expanded', 'true');
    };

    button.addEventListener('click', () => {
      if (menu.classList.contains('active')) {
        closeMenu();
      } else {
        openMenu();
      }
    });

    menu.querySelectorAll('[data-nav-link]').forEach((link) => {
      link.addEventListener('click', closeMenu);
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') {
        closeMenu();
      }
    });
  }

  setupMobileNav();
  document.addEventListener('astro:page-load', setupMobileNav);
</script>
