---
interface Props {
  type?: 'index';
  title: string;
}

const { type, title } = Astro.props;
---

<header class:list={['page-hero', type]}>
  <div class="wrapper">
    <div>
      <slot name="eyebrow" />
      <h1
        class:list={[{ 'page-load-item': type === 'index' }]}
        style={type === 'index' ? '--load-index: 0' : undefined}
      >
        {title}
      </h1>
      <slot />
    </div>
    <div class="image-container">
      <slot name="image" />
    </div>
  </div>
</header>

<style>
  @reference "../styles/global.css";

  .page-hero {
    margin-bottom: 1.5rem;
  }

  .page-hero.index {
    margin-bottom: 4rem;
    margin-top: 1rem;

    @variant md {
      margin-top: 2rem;
    }
  }

  .page-hero.index .wrapper {
    display: flex;
    flex-direction: column-reverse;
    align-items: flex-start;
    gap: 0.5rem;

    @variant md {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      gap: 3rem;
      width: 100%;
    }
  }

  .image-container:empty {
    display: none;
  }

  .page-hero.index .image-container {
    @variant md {
      position: relative;
      flex-shrink: 0;
      margin-top: 4rem;
    }
  }

  .page-hero.index :global(.hero-image-wrap) {
    position: relative;
    flex-shrink: 0;
    width: 100px;
    height: 100px;
    border-radius: 50%;

    @variant md {
      width: 250px;
      height: 250px;
    }
  }

  .page-hero.index :global(.hero-image-wrap)::before {
    background-color: var(--color-orange);
    border-radius: 50%;
    content: '';
    height: 90%;
    position: absolute;
    transform: translate(28%, 25%);
    width: 90%;
    z-index: 0;
  }

  .page-hero.index :global(.hero-image) {
    display: block;
    position: relative;
    z-index: 1;
    width: 100%;
    height: 100%;
    border-radius: 50%;
    object-fit: cover;
    object-position: center;
  }

  h1 {
    font-size: 3.125rem;
    margin-bottom: 1.5rem;
  }
</style>
