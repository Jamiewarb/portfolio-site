---
import WritingList from '@/components/WritingList.astro';
import WritingListItem from '@/components/WritingListItem.astro';
import { getPostsWithReadingTime } from '@/lib/blog';
import { getPublishedNotes } from '@/lib/notes';

interface Props {
  limit?: number;
  loadIndexStart?: number;
}

const { limit = 5, loadIndexStart } = Astro.props;

const posts = await getPublishedNotes({ limit });
const postsWithReadingTime = await getPostsWithReadingTime(posts);
---

{
  postsWithReadingTime.length > 0 ? (
    <WritingList>
      {postsWithReadingTime.map(({ post, minutesRead }, index) => (
        <li
          class:list={[{ 'page-load-item': loadIndexStart !== undefined }]}
          style={loadIndexStart !== undefined ? `--load-index: ${loadIndexStart + index}` : undefined}
        >
          <WritingListItem post={post} minutesRead={minutesRead} />
        </li>
      ))}
    </WritingList>
  ) : (
    <p
      class:list={['notes-empty', { 'page-load-item': loadIndexStart !== undefined }]}
      style={loadIndexStart !== undefined ? `--load-index: ${loadIndexStart}` : undefined}
    >
      No notes yet.
    </p>
  )
}

<style>
  @reference "../styles/global.css";

  .notes-empty {
    margin: 0;
    color: var(--text-muted);
  }
</style>
