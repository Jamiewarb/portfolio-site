---
import { copyrightYearRange } from '../helpers/datetime';
import { ROUTES } from '../constants/routes';
import { SocialLink } from './social/SocialLink';
---

<footer class="footer">
  <div class="footer-inner">
    <div class="footer-left">
      <a class="link footer-rss" href={ROUTES.rss}> RSS Feed </a>

      <nav class="footer-social lg:hidden" aria-label="Social links">
        <SocialLink
          client:load
          href={ROUTES.external.github}
          label="GitHub"
          platform="github"
        />
        <SocialLink
          client:load
          href={ROUTES.external.linkedin}
          label="LinkedIn"
          platform="linkedin"
        />
      </nav>
    </div>

    <section class="footer-content">
      <p>
        Built with <a class="link" href="https://astro.build">Astro</a> and hosted on <a
          class="link"
          href="https://netlify.com">Netlify</a
        >.
      </p>
      <p>
        © {copyrightYearRange('2026')} Jamie Warburton. All rights reserved.
      </p>
    </section>
  </div>
</footer>

<style>
  @reference "../styles/global.css";

  .footer {
    border-top: 1px solid var(--content-border-color);
    color: var(--text-muted);
    font-size: 0.75rem;
    margin-left: calc(-1 * var(--wrapper-padding) + 1.25rem);
    padding: 1.25rem 0;
    padding-bottom: 1.3rem;

    @variant sm {
      font-size: 1rem;
    }
  }

  .footer-inner {
    align-items: flex-start;
    display: flex;
    justify-content: space-between;
  }

  .footer-left {
    align-items: flex-start;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer-rss {
    align-items: center;
    display: inline-flex;
    gap: 0.375rem;
    line-height: 1;
  }

  .footer-social {
    display: flex;
    gap: 0.25rem;

    @variant lg {
      display: none;
    }
  }

  .footer-content {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    text-align: right;
  }
</style>
