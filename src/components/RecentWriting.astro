---
import { humanReadableDate } from '../helpers/datetime';
import { articleDate, getPublishedBlogPosts } from '../lib/blog';

interface Props {
	limit?: number;
}

const { limit = 5 } = Astro.props;

const posts = await getPublishedBlogPosts({ limit });

---

{posts.length > 0 ? (
	<ul class="writing-list">
		{posts.map((post) => {
			const displayDate = articleDate(post);
			return (
				<li>
					<article class="blog">
						<a href={`/writing/${post.id}/`} class="blog-link">
							<time class="blog-date" datetime={displayDate.toISOString()}>
								{humanReadableDate(displayDate)}
							</time>
							<h3 class="blog-title">{post.data.title}</h3>
							<p class="blog-excerpt">{post.data.description}</p>
						</a>
					</article>
				</li>
			);
		})}
	</ul>
) : (
	<p class="writing-empty">No articles yet.</p>
)}

<style>
	@reference "../styles/global.css";

	.writing-list {
		list-style: none;
		margin: 0;
		padding: 0;
	}

	.blog {
		margin: 0;
	}

	.writing-list li + li {
		margin-top: 0.75rem;
	}

	.blog-link {
		display: block;
		color: inherit;
		text-decoration: none;
		border-radius: var(--border-radius);
		margin-left: -0.5rem;
		margin-right: -0.5rem;
		padding: 0.35rem 0.5rem;
	}

	.blog-link:hover,
	.blog-link:focus-visible {
		background-color: var(--link-highlight-color);
		text-decoration: none;
	}

	.blog-date {
		display: block;
		margin: 0 0 0.2rem;
		color: var(--color-neutral-400);
		font-size: 1rem;
		line-height: 1.3;
	}

	.dark .blog-date {
		color: var(--color-neutral-600);
	}

	.blog-title {
		margin: 0 0 0.35rem;
		font-family: var(--font-sans);
		font-size: 1.25rem;
		font-weight: 700;
		line-height: 1.35;

		@variant md {
			font-size: 1.375rem;
		}
	}

	.blog-excerpt {
		margin: 0;
		max-width: 42rem;
		line-height: 1.5;
    font-size: 1.125rem;
	}

	.writing-empty {
		margin: 0;
		color: var(--color-neutral-600);
	}

	.dark .writing-empty {
		color: var(--color-neutral-400);
	}
</style>
