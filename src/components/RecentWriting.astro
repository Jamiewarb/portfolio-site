---
import WritingList from '@/components/WritingList.astro';
import WritingListItem from '@/components/WritingListItem.astro';
import { getPostsWithReadingTime, getPublishedBlogPosts } from '@/lib/blog';

interface Props {
  limit?: number;
}

const { limit = 5 } = Astro.props;

const posts = await getPublishedBlogPosts({ limit });
const postsWithReadingTime = await getPostsWithReadingTime(posts);
---

{
  postsWithReadingTime.length > 0 ? (
    <WritingList>
      {postsWithReadingTime.map(({ post, minutesRead }) => (
        <li>
          <WritingListItem post={post} minutesRead={minutesRead} />
        </li>
      ))}
    </WritingList>
  ) : (
    <p class="writing-empty">No articles yet.</p>
  )
}

<style>
  @reference "../styles/global.css";

  .writing-empty {
    margin: 0;
    color: var(--text-muted);
  }
</style>
