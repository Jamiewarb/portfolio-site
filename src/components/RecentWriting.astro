---
import WritingList from '@/components/WritingList.astro';
import WritingListItem from '@/components/WritingListItem.astro';
import { getPostsWithReadingTime, getPublishedBlogPosts } from '@/lib/blog';

interface Props {
  limit?: number;
  loadIndexStart?: number;
}

const { limit = 5, loadIndexStart } = Astro.props;

const posts = await getPublishedBlogPosts({ limit });
const postsWithReadingTime = await getPostsWithReadingTime(posts);
---

{
  postsWithReadingTime.length > 0 ? (
    <WritingList>
      {postsWithReadingTime.map(({ post, minutesRead }, index) => (
        <li
          class:list={[{ 'fade-in': loadIndexStart !== undefined }]}
          style={
            loadIndexStart !== undefined
              ? `--load-index: ${loadIndexStart + index}`
              : undefined
          }
        >
          <WritingListItem post={post} minutesRead={minutesRead} />
        </li>
      ))}
    </WritingList>
  ) : (
    <p
      class:list={['writing-empty', { 'fade-in': loadIndexStart !== undefined }]}
      style={loadIndexStart !== undefined ? `--load-index: ${loadIndexStart}` : undefined}
    >
      No articles yet.
    </p>
  )
}

<style>
  @reference "../styles/global.css";

  .writing-empty {
    margin: 0;
    color: var(--text-muted);
  }
</style>
