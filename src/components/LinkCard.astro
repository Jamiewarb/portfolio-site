---
interface Props {
  href: string;
  title: string;
  linkLabel: string;
}

const { href, title, linkLabel } = Astro.props;
---

<a class="link-card" href={href}>
  <h2>{title}</h2>
  <p><slot /></p>
  <span class="link-card-cta">{linkLabel} <span aria-hidden="true">&rarr;</span></span>
</a>

<style>
  @reference "../styles/global.css";

  .link-card {
    display: block;
    padding: 1.5rem;
    border: 1px solid var(--content-border-color);
    border-radius: var(--border-radius);
    background-color: var(--input-bg-color);
    color: inherit;
    text-decoration: none;
    transition:
      border-color 0.2s ease,
      background-color 0.2s ease;
  }

  .link-card:hover,
  .link-card:focus-visible {
    border-color: var(--link-color);
    outline: none;
  }

  .link-card h2 {
    margin: 0 0 0.75rem;
    font-size: 1.25rem;
    color: var(--heading-color);
  }

  .link-card p {
    margin: 0 0 1rem;
    max-width: 60ch;
    color: var(--text-muted);
  }

  .link-card-cta {
    color: var(--link-color);
    font-weight: 600;
  }
</style>
