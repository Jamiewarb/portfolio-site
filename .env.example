# Set to false or 0 to disable runtime likes (no Upstash reads/writes; useful for local dev)
LIKES_ENABLED=true

# Upstash (runtime likes)
UPSTASH_LIKES_REST_URL=
UPSTASH_LIKES_REST_TOKEN=
# UPSTASH_LIKES_WRITE_TOKEN is also accepted as an alias for the REST token

# Salt for hashing visitor IPs before storing in Upstash
LIKES_HASH_SALT=

# Secret for /api/likes/sync verification (optional; sync runs via GitHub Actions)
LIKES_SYNC_SECRET=
